<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.CameraFormController"
      spacing="12" prefWidth="380">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Camera Details" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="130"/>
            <ColumnConstraints minWidth="210" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Brand:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="brandComboBox" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Type:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="typeComboBox" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Purpose:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="purposeComboBox" maxWidth="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Release Year:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="releaseYearField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Megapixels:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="megapixelsField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Sensor Type:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="sensorTypeField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="ISO Range:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="isoRangeField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="Max Shooting Speed:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextField fx:id="maxShootingSpeedField" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        <Label text="Price (€):" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <TextField fx:id="priceField" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

        <Label text="Image Path:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <TextField fx:id="imagePathField" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: #d9534f;" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save" onAction="#handleSave" defaultButton="true"
                style="-fx-background-color: #0e85c3; -fx-text-fill: white;"/>
    </HBox>
</VBox>
