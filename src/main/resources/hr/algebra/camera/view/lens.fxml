<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.LensController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Lens Management" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <TableView fx:id="lensTable" VBox.vgrow="ALWAYS"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Add New Lens" onAction="#handleAddLens" style="-fx-background-color: #0e85c3; -fx-text-fill: white;"/>
        <Button text="Edit Selected" onAction="#handleEditLens" style="-fx-background-color: #5bc0de; -fx-text-fill: white;"/>
        <Button text="Delete Selected" onAction="#handleDeleteLens" style="-fx-background-color: #d9534f; -fx-text-fill: white;"/>
    </HBox>
</VBox>
