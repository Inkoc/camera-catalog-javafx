<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.camera.controller.LensController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Lens Management" />
    <TableView fx:id="lensTable" VBox.vgrow="ALWAYS" />
    <HBox fx:id="adminBar" alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#handleAddLens" style="-fx-background-color: #0e85c3; -fx-text-fill: white;" text="Add New Lens" textAlignment="CENTER" />
        <Button onAction="#handleEditLens" style="-fx-background-color: #5bc0de; -fx-text-fill: white;" text="Edit Selected" textAlignment="CENTER" />
        <Button onAction="#handleDeleteLens" style="-fx-background-color: #d9534f; -fx-text-fill: white;" text="Delete Selected" textAlignment="CENTER" />
    </HBox>
</VBox>
