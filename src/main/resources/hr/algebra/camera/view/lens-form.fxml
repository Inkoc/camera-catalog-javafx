<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.LensFormController"
      spacing="12" prefWidth="380">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Lens Details" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="130"/>
            <ColumnConstraints minWidth="210" hgrow="ALWAYS"/>
        </columnConstraints>
        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Focal Length (mm):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="focalLengthField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Aperture (f/):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="apertureField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Mount Type:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="mountTypeField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Price (€):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="priceField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>
    <Label fx:id="errorLabel" style="-fx-text-fill: #d9534f;" wrapText="true"/>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save" onAction="#handleSave" defaultButton="true"
                style="-fx-background-color: #0e85c3; -fx-text-fill: white;"/>
    </HBox>
</VBox>
