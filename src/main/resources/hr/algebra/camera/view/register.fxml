<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.RegisterController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

    <Label alignment="CENTER" prefHeight="33.0" prefWidth="326.0"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;" text="Camera Catalog"/>
    <GridPane alignment="center" hgap="10" prefHeight="114.0" prefWidth="326.0" style="-fx-background-color: #f4f4f4;"
              vgap="12">
        <padding>
            <Insets bottom="30" left="40" right="40" top="30"/>
        </padding>

        <Label text="Username:" GridPane.rowIndex="1"/>
        <TextField fx:id="usernameField" prefWidth="180" promptText="username" GridPane.columnIndex="1"
                   GridPane.rowIndex="1"/>

        <Label text="Password:" GridPane.rowIndex="2"/>
        <PasswordField fx:id="passwordField" promptText="password" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label layoutX="50.0" layoutY="93.0" prefHeight="17.0" prefWidth="100.0" text="Confirm Password:"
               GridPane.rowIndex="3"/>
        <PasswordField fx:id="confirmPasswordField" promptText="repeat password"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>
    <VBox alignment="CENTER">
        <Button alignment="CENTER" contentDisplay="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                minHeight="-Infinity" minWidth="-Infinity" onAction="#handleRegister" prefHeight="32.0"
                prefWidth="172.0"
                style="-fx-background-color: #0e85c3; -fx-text-fill: white; -fx-font-weight: bold;" text="Register"
                textAlignment="CENTER"/>
        <Hyperlink text="Have an account? Log in" onAction="#handleBackToLogin"/>
    </VBox>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
</VBox>
