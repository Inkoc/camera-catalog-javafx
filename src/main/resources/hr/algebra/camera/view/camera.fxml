<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.CameraController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Camera Management" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TableView fx:id="cameraTable" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Add New Camera" onAction="#handleAddCamera" style="-fx-background-color: #0e85c3; -fx-text-fill: white;"/>
        <Button text="Edit Selected" onAction="#handleEditCamera" style="-fx-background-color: #5bc0de; -fx-text-fill: white;"/>
        <Button text="Delete Selected" onAction="#handleDeleteCamera" style="-fx-background-color: #d9534f; -fx-text-fill: white;"/>
        <Button text="Attach Lenses" onAction="#handleAttachLens" style="-fx-background-color: #5cb85c; -fx-text-fill: white;"/>
    </HBox>
</VBox>
