<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.camera.controller.CameraController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Camera Management" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <TextField fx:id="searchField" prefWidth="220" promptText="Search by name…" />
        <ComboBox fx:id="typeFilter" promptText="Any type" />
        <ComboBox fx:id="purposeFilter" promptText="Any purpose" />
        <Button onAction="#handleClearFilters" text="Clear" />
    </HBox>

    <HBox spacing="12" VBox.vgrow="ALWAYS">
        <TableView fx:id="cameraTable" HBox.hgrow="ALWAYS" />
        <VBox prefWidth="220" spacing="6">
            <Label text="Preview" />
            <ImageView fx:id="imagePreview" fitHeight="150" fitWidth="200" preserveRatio="true" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button onAction="#handleAddCamera" style="-fx-background-color: #0e85c3; -fx-text-fill: white;" text="Add New Camera" />
        <Button onAction="#handleEditCamera" style="-fx-background-color: #5bc0de; -fx-text-fill: white;" text="Edit Selected" />
        <Button onAction="#handleDeleteCamera" style="-fx-background-color: #d9534f; -fx-text-fill: white;" text="Delete Selected" />
        <Button onAction="#handleAttachLens" style="-fx-background-color: #5cb85c; -fx-text-fill: white;" text="Attach Lenses" />
    </HBox>
</VBox>
