<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.camera.controller.LensAttachController"
      spacing="10" prefWidth="560" prefHeight="420">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
    <Label fx:id="titleLabel" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <Label text="Drag a lens between the lists to attach / detach."
           style="-fx-text-fill: #666;"/>
    <HBox spacing="12" VBox.vgrow="ALWAYS">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Available"/>
            <ListView fx:id="availableList" VBox.vgrow="ALWAYS"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Attached"/>
            <ListView fx:id="attachedList" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>
    <HBox alignment="CENTER_RIGHT">
        <Button text="Close" onAction="#handleClose" defaultButton="true"/>
    </HBox>
</VBox>
