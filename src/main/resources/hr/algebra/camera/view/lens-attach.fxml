<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="420" prefWidth="560" spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.camera.controller.LensAttachController">
    <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
    <Label fx:id="titleLabel" style="-fx-font-size: 16; -fx-font-weight: bold;" />
    <Label style="-fx-text-fill: #666;" text="Drag a lens between the lists to attach / detach." />
    <HBox spacing="12" VBox.vgrow="ALWAYS">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Available" />
            <ListView fx:id="availableList" VBox.vgrow="ALWAYS" />
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Attached" />
            <ListView fx:id="attachedList" VBox.vgrow="ALWAYS" />
        </VBox>
    </HBox>
    <HBox alignment="CENTER">
        <Button defaultButton="true" onAction="#handleClose" prefHeight="25.0" prefWidth="82.0" text="Close" />
    </HBox>
</VBox>
