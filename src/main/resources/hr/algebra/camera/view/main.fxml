<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.algebra.camera.controller.MainController"
            prefWidth="900" prefHeight="650">
    <top>
        <MenuBar>
            <menus>
                <Menu text="Katalog">
                    <items>
                        <MenuItem text="Kamere" onAction="#handleCameras"/>
                        <MenuItem text="Objektivi" onAction="#handleLenses"/>
                    </items>
                </Menu>
                <Menu text="Admin">
                    <items>
                        <MenuItem text="Upravljanje podacima" onAction="#handleAdmin"/>
                    </items>
                </Menu>
                <Menu text="Korisnik">
                    <items>
                        <MenuItem text="Odjava" onAction="#handleLogout"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="12">
            <padding><Insets top="40"/></padding>
            <Label text="Dobrodosli u Camera Catalog!"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Navigirajte koristeci gornji izbornik."
                   style="-fx-font-size: 13; -fx-text-fill: #777;"/>
        </VBox>
    </center>
    <bottom>
        <Label text="Camera Catalog v1.0"
               style="-fx-font-size: 11; -fx-text-fill: #aaa; -fx-padding: 5 10;"/>
    </bottom>
</BorderPane>