<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.camera.controller.MainController">
    <top>
        <MenuBar>
            <Menu text="Catalog">
                <MenuItem onAction="#handleCameras" text="Cameras" />
                <MenuItem onAction="#handleLenses" text="Lenses" />
            </Menu>
            <Menu text="Admin">
                <MenuItem onAction="#handleAdmin" text="Data Management" />
            </Menu>
            <Menu text="User">
                <MenuItem onAction="#handleLogout" text="Logout" />
            </Menu>
        </MenuBar>
    </top>
    <center>
        <VBox alignment="CENTER" prefHeight="601.0" prefWidth="900.0" spacing="12">
            <padding><Insets top="40" /></padding>
            <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;" text="Welcome to Camera Catalog!" />
            <Label style="-fx-font-size: 13; -fx-text-fill: #777;" text="Navigate using the menu above." />
        </VBox>
    </center>
    <bottom>
        <Label style="-fx-font-size: 11; -fx-text-fill: #aaa; -fx-padding: 5 10;" text="Camera Catalog v1.0" />
    </bottom>
</BorderPane>
