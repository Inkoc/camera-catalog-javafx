<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.algebra.camera.controller.MainController"
            prefWidth="900" prefHeight="650">
    <top>
        <MenuBar>
            <Menu text="Catalog">
                <MenuItem text="Cameras" onAction="#handleCameras"/>
                <MenuItem text="Lenses" onAction="#handleLenses"/>
            </Menu>
            <Menu text="Admin">
                <MenuItem text="Data Management" onAction="#handleAdmin"/>
            </Menu>
            <Menu text="User">
                <MenuItem text="Logout" onAction="#handleLogout"/>
            </Menu>
        </MenuBar>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="12">
            <padding><Insets top="40"/></padding>
            <Label text="Welcome to Camera Catalog!"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Navigate using the menu above."
                   style="-fx-font-size: 13; -fx-text-fill: #777;"/>
        </VBox>
    </center>
    <bottom>
        <Label text="Camera Catalog v1.0"
               style="-fx-font-size: 11; -fx-text-fill: #aaa; -fx-padding: 5 10;"/>
    </bottom>
</BorderPane>